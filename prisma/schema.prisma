// prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"

}

// ===== Users & Auth =====
model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Properties =====
model Property {
  id              String   @id @default(cuid())
  slug            String   @unique
  nameId          String
  nameEn          String
  type            String   // 'hotel' | 'kos' | 'apartemen' | 'rumah'
  locationId      String
  locationEn      String
  mapsUrl         String?
  capacityMin     Int
  capacityMax     Int
  pricingWeekday  Int?
  pricingWeekend  Int?
  pricingMode     String?  // 'general' | 'wni-wna' (khusus kos)
  monthlyPrice    Int?     // mode general
  monthlyPricingWNI Int?   // mode wni-wna
  monthlyPricingWNA Int?   // mode wni-wna
  extraChargeAmount Int?
  extraChargeUnit  String? // 'per_person' | 'per_group'
  deposit         Int?
  description     String
  descriptionEn   String
  image           String
  images          String[]
  imagesCategorized Json? 
  facilities      Json?    // [{ label: string, labelEn: string, icon: string }]
  rules           String[]
  rulesEn         String[]
  notes           String?
  notesEn         String?
  isGroupFriendly Boolean  @default(false)
  minGroupSize    Int?
  version         Int      @default(1) // NEW: optimistic locking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  units      PropertyUnit[]
  roomTypes  RoomType[]        // NEW: untuk Hotel
  promos     PromoProperty[]
  bookings   Booking[]
}

// ===== Property Units (untuk Kos, Apartemen, Rumah) =====
model PropertyUnit {
  id          String   @id @default(cuid())
  unitId      String   @unique
  unitName    String
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, unitName])   // <-- TAMBAHAN UNTUK CEGAH DUPLIKAT
}

// ===== Room Types & Rooms (khusus Hotel) =====
model RoomType {
  id          String   @id @default(cuid())
  roomTypeId  String   @unique
  nameId      String
  nameEn      String
  capacity    Int
  priceWeekend       Int      // harga per malam
  priceWeekday        Int
  images String[] @default([])
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms       Room[]   // nested rooms (nomor kamar)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id          String   @id @default(cuid())
  roomId      String   @unique
  roomNumber  String   // internal admin only
  roomTypeId  String
  roomType    RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Promos =====
model Promo {
  id              String   @id @default(cuid())
  titleId         String
  titleEn         String
  descriptionId   String
  descriptionEn   String
  image           String
  validUntil      String   // ISO date
  active          Boolean  @default(true)
  version         Int      @default(1) // NEW: optimistic locking
  properties      PromoProperty[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PromoProperty {
  id          String   @id @default(cuid())
  promoId     String
  promo       Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// ===== Booking Availability =====
model Booking {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitId      String?
  unit        PropertyUnit? @relation(fields: [unitId], references: [id])
  roomId      String?  // NEW: untuk Hotel (booking per room)
  room        Room?    @relation(fields: [roomId], references: [id])
  startDate   String   // ISO date
  endDate     String   // ISO date (eksklusif)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== FAQs =====
model FAQ {
  id                String   @id @default(cuid())
  categoryId        String
  categoryEn        String
  questionId        String
  questionEn        String
  answerIdContent   String
  answerEnContent   String
  version           Int      @default(1) // NEW: optimistic locking
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ===== About =====
model About {
  id          String   @id @default(cuid())
  mission     String
  missionEn   String
  ctaTitle    String
  ctaTitleEn  String
  ctaDesc     String
  ctaDescEn   String
  values      Json
  whyChooseUs Json
  version     Int      @default(1) // NEW: optimistic locking
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Home Content =====
model HomeContent {
  id              String   @id @default(cuid())
  heroTitleId     String
  heroTitleEn     String
  heroSubtitleId  String
  heroSubtitleEn  String
  heroCtaPrimaryId  String
  heroCtaPrimaryEn  String
  heroCtaSecondaryId String
  heroCtaSecondaryEn String
  heroImage       String
  propertyTypes   Json
  whyUs           Json
  reviews         Json
  version         Int      @default(1) // NEW: optimistic locking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== Site Settings =====
model SiteSetting {
  id              String   @id @default(cuid())
  siteName        String
  logoText        String
  whatsappNumber  String
  email           String
  instagramUrl    String
  footerTagline   String
  copyrightText   String
  navLinks        Json
  version         Int      @default(1) // NEW: optimistic locking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== Appearance Settings =====
model AppearanceSetting {
  id                String   @id @default(cuid())
  primaryColor      String
  accentColor       String
  backgroundColor   String
  version           Int      @default(1) // NEW: optimistic locking
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}